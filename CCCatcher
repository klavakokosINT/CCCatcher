-- Контент
local ContentFrame = makeFrame(MainFrame, UDim2.new(1,0,1,-39), UDim2.new(0,0,0,39), Color3.fromRGB(28,28,28))
ContentFrame.BackgroundTransparency = 1

local function makeLabel(parent, size, pos, text, color, fontSize, font, align)
	local l = Instance.new("TextLabel", parent)
	l.Size = size
	l.Position = pos
	l.Text = text
	l.TextColor3 = color
	l.BackgroundTransparency = 1
	l.Font = font or Enum.Font.SourceSans
	l.TextSize = fontSize or 12
	l.TextXAlignment = align or Enum.TextXAlignment.Left
	return l
end

