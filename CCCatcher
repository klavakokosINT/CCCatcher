Instance.new("UIStroke", MainFrame).Color = Color3.fromRGB(70, 70, 70)

local function makeFrame(parent, size, pos, color)
	local f = Instance.new("Frame", parent)
	f.Size = size
	f.Position = pos
	f.BackgroundColor3 = color
	f.BorderSizePixel = 0
	return f
end

