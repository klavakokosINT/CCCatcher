if not game:IsLoaded() then game.Loaded:Wait() end

local localPlayer = game:GetService("Players").LocalPlayer
local autoCollect = false
local clientEffects = workspace:FindFirstChild("ClientEffects") or workspace:FindFirstChild("Particles")

local function teleportToCombo(obj)
	if not autoCollect then return end
	if obj:IsA("BasePart") and obj.Name:find("Combo") then
		local root = localPlayer.Character and localPlayer.Character:FindFirstChild("HumanoidRootPart")
		if root then
			root.CFrame = CFrame.new(obj.Position.X, root.Position.Y, obj.Position.Z)
		end
	end
end

