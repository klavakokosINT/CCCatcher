if not game:IsLoaded() then game.Loaded:Wait() end

local localPlayer = game:GetService("Players").LocalPlayer
local autoCollect = false

local function findPriorityCFrame()
	local char = localPlayer.Character
	local root = char and char:FindFirstChild("HumanoidRootPart")
	if not root then return nil end

	local effects = workspace:FindFirstChild("ClientEffects") or workspace:FindFirstChild("Particles")
	if not effects then return nil end

	local currentY = root.Position.Y
	local bestCombo, bestCoco = nil, nil
	local distCombo, distCoco = math.huge, math.huge

	for _, obj in ipairs(effects:GetChildren()) do
		if obj:IsA("BasePart") then
			local name = obj.Name
			local dist = (obj.Position - root.Position).Magnitude

			if name:find("Combo") or name:find("CocoCombo") then
				if dist < distCombo then
					distCombo = dist
					bestCombo = obj.Position
				end
			elseif name:find("Coco") or name == "Circle" then
				if dist < distCoco then
					distCoco = dist
					bestCoco = obj.Position
				end
			end
		end
	end

	local pos = bestCombo or bestCoco
	return pos and CFrame.new(pos.X, currentY, pos.Z)
end

