	Enum.TextXAlignment.Center)

-- Логика кнопки
ToggleBtn.MouseButton1Click:Connect(function()
	autoCollect = not autoCollect
	if autoCollect then
		ToggleBtn.BackgroundColor3 = Color3.fromRGB(255,255,255)
		ToggleBtn.TextColor3 = Color3.fromRGB(0,0,0)
		BtnStroke.Color = Color3.fromRGB(200,200,200)
		StatusLabel.Text = "● ACTIVE"
		StatusLabel.TextColor3 = Color3.fromRGB(40,205,65)
		if clientEffects then
			for _, obj in ipairs(clientEffects:GetChildren()) do
				teleportToCombo(obj)
			end
		end
	else
		ToggleBtn.BackgroundColor3 = Color3.fromRGB(45,45,45)
		ToggleBtn.TextColor3 = Color3.fromRGB(180,180,180)
		BtnStroke.Color = Color3.fromRGB(65,65,65)
		StatusLabel.Text = "● INACTIVE"
		StatusLabel.TextColor3 = Color3.fromRGB(120,120,120)
	end
end)

-- Свернуть
local minimized = false
btnMinimize.MouseButton1Click:Connect(function()
	minimized = not minimized
	ContentFrame.Visible = not minimized
	MainFrame.Size = minimized
		and UDim2.new(0,236,0,38)
		or  UDim2.new(0,236,0,164)
end)

-- Закрыть
local childConn
if clientEffects then
	childConn = clientEffects.ChildAdded:Connect(teleportToCombo)
end

btnClose.MouseButton1Click:Connect(function()
	autoCollect = false
	if childConn then childConn:Disconnect() end
	ScreenGui:Destroy()
end)
